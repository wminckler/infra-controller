ESA_PORT=8080
METRICS_PORT=2112
DEV_MODE=true
ENABLE_DEBUG=true
ENABLE_TLS=false
NICO_ADDRESS=localhost:11079
NICO_SEC_OPT=0
NICO_CA_CERT_PATH=/tmp/site-agent/nico/ca.crt
NICO_CLIENT_CERT_PATH=/tmp/site-agent/nico/tls.crt
NICO_CLIENT_KEY_PATH=/tmp/site-agent/nico/tls.key
CLUSTER_ID=e3ad6ade-2525-49ab-9aad-7345872c462c
TEMPORAL_HOST=temporal.test.com
TEMPORAL_PORT=7233
TEMPORAL_PUBLISH_NAMESPACE=site
TEMPORAL_PUBLISH_QUEUE=site
TEMPORAL_SUBSCRIBE_NAMESPACE=e3ad6ade-2525-49ab-9aad-7345872c462c
TEMPORAL_SUBSCRIBE_QUEUE=e3ad6ade-2525-49ab-9aad-7345872c462c
BOOTSTRAP_SECRET=/tmp/site-agent/bootstrap/
TEMPORAL_CERT_PATH=/tmp/site-agent/temporal
POD_NAME=elektra-site-agent-0
POD_NAMESPACE=elektra-site-agent
FLOW_ENABLED=true
FLOW_ADDRESS=localhost:11080
FLOW_SEC_OPT=0
FLOW_CA_CERT_PATH=/tmp/site-agent/nico/ca.crt
FLOW_CLIENT_CERT_PATH=/tmp/site-agent/nico/tls.crt
FLOW_CLIENT_KEY_PATH=/tmp/site-agent/nico/tls.key
SKIP_FLOW_GRPC_SERVER_AUTH=true
OTEL_EXPORTER_OTLP_SPAN_INSECURE=true
OTEL_EXPORTER_OTLP_SPAN_ENDPOINT=""
